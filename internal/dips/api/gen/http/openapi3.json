  "info": {
    "description": "The DIPs API is used to request DIP creation and retrieve DIP details.",
    "title": "DIPs API",
    "version": "0.1.0"
  },
  "openapi": "3.0.3",
  "paths": {
    "/dips": {
      "post": {
        "description": "The create method requests DIP creation for a document key.",
        "operationId": "DIPs#create",
        "requestBody": {
          "content": {
            "application/json": {
              "example": {
                "docKey": "CH-000001"
              },
              "schema": {
                "example": {
                  "docKey": "CH-000001"
                },
                "properties": {
                  "docKey": {
                    "description": "The docKey field contains the document key used to create the DIP.",
                    "example": "CH-000001",
                    "minLength": 1,
                    "type": "string"
                  }
                },
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "content": {
              "application/json": {
                "example": {
                  "id": "3f38d6f4-7b19-4db8-8d7d-693b84a9a2fb"
                },
                "schema": {
                  "$ref": "#/components/schemas/CreateDIPResult"
                }
              }
            },
            "description": "Accepted response."
          },
          "400": {
            "content": {
              "application/problem+json": {
                "example": {
                  "code": "400-03",
                  "detail": "The request is missing an expected query or path parameter.",
                  "errors": [
                    {
                      "detail": "The 'docKey' field is required.",
                      "parameter": "docKey"
                    }
                  ],
                  "status": 400,
                  "title": "Missing Request Parameter",
                  "type": "https://problems-registry.smartbear.com/missing-request-parameter"
                },
                "schema": {
                  "$ref": "#/components/schemas/MissingReqParamError"
                }
              }
            },
            "description": "missing_req_param: Bad Request response."
          },
          "401": {
            "content": {
              "application/problem+json": {
                "example": {
                  "detail": "The request body is missing the docKey field.",
                  "status": 400,
                  "title": "Invalid request parameters.",
                  "type": "about:blank"
                },
                "schema": {
                  "$ref": "#/components/schemas/UnauthorizedError"
                }
              }
            },
            "description": "unauthorized: Unauthorized response."
          },
          "500": {
            "content": {
              "application/problem+json": {
                "example": {
                  "detail": "The request body is missing the docKey field.",
                  "status": 400,
                  "title": "Invalid request parameters.",
                  "type": "about:blank"
                },
                "schema": {
                  "$ref": "#/components/schemas/InternalError"
                }
              }
            },
            "description": "internal: Internal Server Error response."
          }
        },
        "security": [
          {
            "bearer_header_Authorization": []
          }
        ],
        "summary": "create DIPs",
        "tags": [
          "DIPs"
        ]
      }
    },
