{
  "components": {
    "schemas": {
      "CreateDIPResult": {
        "description": "DIP creation request result.",
        "example": {
          "id": "3f38d6f4-7b19-4db8-8d7d-693b84a9a2fb"
        },
        "properties": {
          "id": {
            "description": "DIP identifier.",
            "example": "3f38d6f4-7b19-4db8-8d7d-693b84a9a2fb",
            "format": "uuid",
            "type": "string"
          }
        },
        "required": [
          "id"
        ],
        "type": "object"
      },
      "DIP": {
        "description": "DIP details.",
        "example": {
          "completed_at": "2026-05-27T15:04:05Z",
          "created_at": "2026-05-27T15:04:05Z",
          "docKey": "CH-000001",
          "id": "3f38d6f4-7b19-4db8-8d7d-693b84a9a2fb",
          "object_key": "dips/3f38d6f4-7b19-4db8-8d7d-693b84a9a2fb.zip",
          "started_at": "2026-05-27T15:04:05Z",
          "status": "done"
        },
        "properties": {
          "completed_at": {
            "description": "RFC3339 timestamp.",
            "example": "2026-05-27T15:04:05Z",
            "format": "date-time",
            "type": "string"
          },
          "created_at": {
            "description": "RFC3339 timestamp.",
            "example": "2026-05-27T15:04:05Z",
            "format": "date-time",
            "type": "string"
          },
          "docKey": {
            "description": "Document key.",
            "example": "CH-000001",
            "minLength": 1,
            "type": "string"
          },
          "id": {
            "description": "DIP identifier.",
            "example": "3f38d6f4-7b19-4db8-8d7d-693b84a9a2fb",
            "format": "uuid",
            "type": "string"
          },
          "object_key": {
            "description": "Object store key for the completed DIP.",
            "example": "dips/3f38d6f4-7b19-4db8-8d7d-693b84a9a2fb.zip",
            "minLength": 1,
            "type": "string"
          },
          "started_at": {
            "description": "RFC3339 timestamp.",
            "example": "2026-05-27T15:04:05Z",
            "format": "date-time",
            "type": "string"
          },
          "status": {
            "description": "Current DIP status.",
            "enum": [
              "queued",
              "in progress",
              "done",
              "failed"
            ],
            "example": "done",
            "type": "string"
          }
        },
        "required": [
          "id",
          "docKey",
          "status",
          "created_at"
        ],
        "type": "object"
      },
      "ProblemDetails": {
        "description": "RFC 9457 problem details object.",
        "example": {
          "detail": "The request body is missing the docKey field.",
          "status": 400,
          "title": "Invalid request parameters.",
          "type": "/problems/not-valid"
        },
        "properties": {
          "detail": {
            "description": "Human-readable explanation specific to this problem occurrence.",
            "example": "The request body is missing the docKey field.",
            "type": "string"
          },
          "instance": {
            "description": "URI reference that identifies this problem occurrence.",
            "type": "string"
          },
          "status": {
            "description": "HTTP status code generated by the origin server.",
            "example": 400,
            "format": "int64",
            "type": "integer"
          },
          "title": {
            "description": "Short, human-readable summary of the problem type.",
            "example": "Invalid request parameters.",
            "type": "string"
          },
          "type": {
            "description": "URI reference that identifies the problem type.",
            "enum": [
              "/problems/unauthorized",
              "/problems/not-valid",
              "/problems/not-found",
              "/problems/internal-error"
            ],
            "example": "/problems/not-valid",
            "format": "uri",
            "type": "string"
          }
        },
        "required": [
          "type",
          "title",
          "status",
          "detail"
        ],
        "type": "object"
      }
    },
    "securitySchemes": {
      "bearer_header_Authorization": {
        "description": "Authenticate with an access token supplied as Authorization: Bearer [token]. Clients obtain tokens from an external OIDC provider.",
        "scheme": "bearer",
        "type": "http"
      }
    }
  },
  "info": {
    "description": "API used to request DIP creation and poll DIP details.",
    "title": "DIPs API",
    "version": "0.1.0"
  },
  "openapi": "3.0.3",
  "paths": {
    "/dips": {
      "post": {
        "description": "Request DIP creation for a document key.",
        "operationId": "DIPs#create",
        "requestBody": {
          "content": {
            "application/json": {
              "example": {
                "docKey": "CH-000001"
              },
              "schema": {
                "example": {
                  "docKey": "CH-000001"
                },
                "properties": {
                  "docKey": {
                    "description": "Document key used to create the DIP.",
                    "example": "CH-000001",
                    "minLength": 1,
                    "type": "string"
                  }
                },
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "content": {
              "application/json": {
                "example": {
                  "id": "3f38d6f4-7b19-4db8-8d7d-693b84a9a2fb"
                },
                "schema": {
                  "$ref": "#/components/schemas/CreateDIPResult"
                }
              }
            },
            "description": "Accepted response."
          },
          "400": {
            "content": {
              "application/problem+json": {
                "example": {
                  "detail": "The request body is missing the docKey field.",
                  "status": 400,
                  "title": "Invalid request parameters.",
                  "type": "/problems/not-valid"
                },
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            },
            "description": "/problems/not-valid: Invalid request parameters."
          },
          "401": {
            "content": {
              "application/problem+json": {
                "example": {
                  "detail": "The Authorization header is missing or invalid.",
                  "status": 401,
                  "title": "Invalid bearer token.",
                  "type": "/problems/unauthorized"
                },
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            },
            "description": "/problems/unauthorized: Missing or invalid bearer token."
          },
          "500": {
            "content": {
              "application/problem+json": {
                "example": {
                  "detail": "The DIP request could not be processed.",
                  "status": 500,
                  "title": "Unexpected server error.",
                  "type": "/problems/internal-error"
                },
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            },
            "description": "/problems/internal-error: Unexpected server error."
          }
        },
        "security": [
          {
            "bearer_header_Authorization": []
          }
        ],
        "summary": "create DIPs",
        "tags": [
          "DIPs"
        ]
      }
    },
    "/dips/{id}": {
      "get": {
        "description": "Get DIP details.",
        "operationId": "DIPs#show",
        "parameters": [
          {
            "description": "DIP identifier.",
            "example": "3f38d6f4-7b19-4db8-8d7d-693b84a9a2fb",
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "description": "DIP identifier.",
              "example": "3f38d6f4-7b19-4db8-8d7d-693b84a9a2fb",
              "format": "uuid",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "example": {
                  "completed_at": "2026-05-27T15:04:05Z",
                  "created_at": "2026-05-27T15:04:05Z",
                  "docKey": "CH-000001",
                  "id": "3f38d6f4-7b19-4db8-8d7d-693b84a9a2fb",
                  "object_key": "dips/3f38d6f4-7b19-4db8-8d7d-693b84a9a2fb.zip",
                  "started_at": "2026-05-27T15:04:05Z",
                  "status": "done"
                },
                "schema": {
                  "$ref": "#/components/schemas/DIP"
                }
              }
            },
            "description": "OK response."
          },
          "401": {
            "content": {
              "application/problem+json": {
                "example": {
                  "detail": "The Authorization header is missing or invalid.",
                  "status": 401,
                  "title": "Invalid bearer token.",
                  "type": "/problems/unauthorized"
                },
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            },
            "description": "/problems/unauthorized: Missing or invalid bearer token."
          },
          "404": {
            "content": {
              "application/problem+json": {
                "example": {
                  "detail": "The requested DIP does not exist.",
                  "status": 404,
                  "title": "DIP not found.",
                  "type": "/problems/not-found"
                },
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            },
            "description": "/problems/not-found: DIP not found."
          },
          "500": {
            "content": {
              "application/problem+json": {
                "example": {
                  "detail": "The DIP request could not be processed.",
                  "status": 500,
                  "title": "Unexpected server error.",
                  "type": "/problems/internal-error"
                },
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            },
            "description": "/problems/internal-error: Unexpected server error."
          }
        },
        "security": [
          {
            "bearer_header_Authorization": []
          }
        ],
        "summary": "show DIPs",
        "tags": [
          "DIPs"
        ]
      }
    }
  },
  "servers": [
    {
      "description": "Default server for DIPs",
      "url": "http://localhost:80"
    }
  ],
  "tags": [
    {
      "description": "Requests DIP creation and reports DIP details.",
      "name": "DIPs"
    }
  ]
}
