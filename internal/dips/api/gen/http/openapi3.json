{
  "components": {
    "schemas": {
      "CreateDIPResult": {
        "description": "CreateDIPResult contains the result of a DIP creation request.",
        "example": {
          "id": "3f38d6f4-7b19-4db8-8d7d-693b84a9a2fb"
        },
        "properties": {
          "id": {
            "description": "DIPID uniquely identifies a DIP.",
            "example": "3f38d6f4-7b19-4db8-8d7d-693b84a9a2fb",
            "format": "uuid",
            "type": "string"
          }
        },
        "required": [
          "id"
        ],
        "type": "object"
      },
      "DIP": {
        "description": "DIP represents the details of a DIP.",
        "example": {
          "completed_at": "2026-05-27T15:04:05Z",
          "created_at": "2026-05-27T15:04:05Z",
          "docKey": "CH-000001",
          "id": "3f38d6f4-7b19-4db8-8d7d-693b84a9a2fb",
          "object_key": "dips/3f38d6f4-7b19-4db8-8d7d-693b84a9a2fb.zip",
          "started_at": "2026-05-27T15:04:05Z",
          "status": "done"
        },
        "properties": {
          "completed_at": {
            "description": "DateTime represents an RFC3339 timestamp.",
            "example": "2026-05-27T15:04:05Z",
            "format": "date-time",
            "type": "string"
          },
          "created_at": {
            "description": "DateTime represents an RFC3339 timestamp.",
            "example": "2026-05-27T15:04:05Z",
            "format": "date-time",
            "type": "string"
          },
          "docKey": {
            "description": "DocKey is the document key used to create a DIP.",
            "example": "CH-000001",
            "minLength": 1,
            "type": "string"
          },
          "id": {
            "description": "DIPID uniquely identifies a DIP.",
            "example": "3f38d6f4-7b19-4db8-8d7d-693b84a9a2fb",
            "format": "uuid",
            "type": "string"
          },
          "object_key": {
            "description": "ObjectKey represents the object store key for a DIP.",
            "example": "dips/3f38d6f4-7b19-4db8-8d7d-693b84a9a2fb.zip",
            "minLength": 1,
            "type": "string"
          },
          "started_at": {
            "description": "DateTime represents an RFC3339 timestamp.",
            "example": "2026-05-27T15:04:05Z",
            "format": "date-time",
            "type": "string"
          },
          "status": {
            "description": "DIPStatus represents the current status of a DIP.",
            "enum": [
              "queued",
              "in progress",
              "done",
              "failed"
            ],
            "example": "done",
            "type": "string"
          }
        },
        "required": [
          "id",
          "docKey",
          "status",
          "created_at"
        ],
        "type": "object"
      },
      "ProblemDetails": {
        "description": "ProblemDetails represents an RFC 9457 problem details object.",
        "example": {
          "detail": "The request body is missing the docKey field.",
          "status": 400,
          "title": "Bad Request",
          "type": "about:blank"
        },
        "properties": {
          "detail": {
            "description": "The detail field contains a human-readable explanation specific to this problem occurrence.",
            "example": "The request body is missing the docKey field.",
            "type": "string"
          },
          "instance": {
            "description": "The instance field contains a URI reference that identifies this problem occurrence.",
            "type": "string"
          },
          "status": {
            "description": "The status field contains the HTTP status code generated by the origin server.",
            "example": 400,
            "format": "int32",
            "type": "integer"
          },
          "title": {
            "description": "The title field contains a short, human-readable summary of the problem type.",
            "example": "Bad Request",
            "type": "string"
          },
          "type": {
            "default": "about:blank",
            "description": "The type field contains a URI reference that identifies the problem type.",
            "example": "about:blank",
            "format": "uri",
            "type": "string"
          }
        },
        "required": [
          "type",
          "title",
          "status",
          "detail"
        ],
        "type": "object"
      }
    },
    "securitySchemes": {
      "bearer_header_Authorization": {
        "description": "Authenticate with an access token supplied as Authorization: Bearer [token]. Clients obtain tokens from an external OIDC provider.",
        "scheme": "bearer",
        "type": "http"
      }
    }
  },
  "info": {
    "description": "The DIPs API is used to request DIP creation and retrieve DIP details.",
    "title": "DIPs API",
    "version": "0.1.0"
  },
  "openapi": "3.0.3",
  "paths": {
    "/dips": {
      "post": {
        "description": "The create method requests DIP creation for a document key.",
        "operationId": "DIPs#create",
        "requestBody": {
          "content": {
            "application/json": {
              "example": {
                "docKey": "CH-000001"
              },
              "schema": {
                "example": {
                  "docKey": "CH-000001"
                },
                "properties": {
                  "docKey": {
                    "description": "The docKey field contains the document key used to create the DIP.",
                    "example": "CH-000001",
                    "minLength": 1,
                    "type": "string"
                  }
                },
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "content": {
              "application/json": {
                "example": {
                  "id": "3f38d6f4-7b19-4db8-8d7d-693b84a9a2fb"
                },
                "schema": {
                  "$ref": "#/components/schemas/CreateDIPResult"
                }
              }
            },
            "description": "Accepted response."
          },
          "400": {
            "content": {
              "application/problem+json": {
                "example": {
                  "detail": "The request body is missing the docKey field.",
                  "status": 400,
                  "title": "Bad Request",
                  "type": "about:blank"
                },
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            },
            "description": "not_valid: The request parameters are invalid."
          },
          "401": {
            "content": {
              "application/problem+json": {
                "example": {
                  "detail": "The Authorization header is missing or invalid.",
                  "status": 401,
                  "title": "Unauthorized",
                  "type": "about:blank"
                },
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            },
            "description": "unauthorized: The bearer token is missing or invalid."
          },
          "500": {
            "content": {
              "application/problem+json": {
                "example": {
                  "detail": "The DIP request could not be processed.",
                  "status": 500,
                  "title": "Internal Server Error",
                  "type": "about:blank"
                },
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            },
            "description": "internal_error: An unexpected server error occurred."
          }
        },
        "security": [
          {
            "bearer_header_Authorization": []
          }
        ],
        "summary": "create DIPs",
        "tags": [
          "DIPs"
        ]
      }
    },
    "/dips/{id}": {
      "get": {
        "description": "The show method retrieves DIP details.",
        "operationId": "DIPs#show",
        "parameters": [
          {
            "description": "The id field contains the DIP identifier.",
            "example": "3f38d6f4-7b19-4db8-8d7d-693b84a9a2fb",
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "description": "DIPID uniquely identifies a DIP.",
              "example": "3f38d6f4-7b19-4db8-8d7d-693b84a9a2fb",
              "format": "uuid",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "example": {
                  "completed_at": "2026-05-27T15:04:05Z",
                  "created_at": "2026-05-27T15:04:05Z",
                  "docKey": "CH-000001",
                  "id": "3f38d6f4-7b19-4db8-8d7d-693b84a9a2fb",
                  "object_key": "dips/3f38d6f4-7b19-4db8-8d7d-693b84a9a2fb.zip",
                  "started_at": "2026-05-27T15:04:05Z",
                  "status": "done"
                },
                "schema": {
                  "$ref": "#/components/schemas/DIP"
                }
              }
            },
            "description": "OK response."
          },
          "401": {
            "content": {
              "application/problem+json": {
                "example": {
                  "detail": "The Authorization header is missing or invalid.",
                  "status": 401,
                  "title": "Unauthorized",
                  "type": "about:blank"
                },
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            },
            "description": "unauthorized: The bearer token is missing or invalid."
          },
          "404": {
            "content": {
              "application/problem+json": {
                "example": {
                  "detail": "The requested DIP does not exist.",
                  "status": 404,
                  "title": "Not Found",
                  "type": "about:blank"
                },
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            },
            "description": "not_found: The requested DIP was not found."
          },
          "500": {
            "content": {
              "application/problem+json": {
                "example": {
                  "detail": "The DIP request could not be processed.",
                  "status": 500,
                  "title": "Internal Server Error",
                  "type": "about:blank"
                },
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            },
            "description": "internal_error: An unexpected server error occurred."
          }
        },
        "security": [
          {
            "bearer_header_Authorization": []
          }
        ],
        "summary": "show DIPs",
        "tags": [
          "DIPs"
        ]
      }
    }
  },
  "servers": [
    {
      "description": "Default server for DIPs",
      "url": "http://localhost:80"
    }
  ],
  "tags": [
    {
      "description": "The DIPs service requests DIP creation and retrieves DIP details.",
      "name": "DIPs"
    }
  ]
}
