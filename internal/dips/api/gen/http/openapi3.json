{
  "components": {
    "schemas": {
      "CreateDIPResult": {
        "description": "DIP creation request result.",
        "example": {
          "id": "3f38d6f4-7b19-4db8-8d7d-693b84a9a2fb"
        },
        "properties": {
          "id": {
            "description": "DIP identifier.",
            "example": "3f38d6f4-7b19-4db8-8d7d-693b84a9a2fb",
            "format": "uuid",
            "type": "string"
          }
        },
        "required": [
          "id"
        ],
        "type": "object"
      },
      "DIP": {
        "description": "DIP details.",
        "example": {
          "completed_at": "2026-05-27T15:04:05Z",
          "created_at": "2026-05-27T15:04:05Z",
          "docKey": "CH-000001",
          "id": "3f38d6f4-7b19-4db8-8d7d-693b84a9a2fb",
          "object_key": "dips/3f38d6f4-7b19-4db8-8d7d-693b84a9a2fb.zip",
          "started_at": "2026-05-27T15:04:05Z",
          "status": "done"
        },
        "properties": {
          "completed_at": {
            "description": "RFC3339 timestamp.",
            "example": "2026-05-27T15:04:05Z",
            "format": "date-time",
            "type": "string"
          },
          "created_at": {
            "description": "RFC3339 timestamp.",
            "example": "2026-05-27T15:04:05Z",
            "format": "date-time",
            "type": "string"
          },
          "docKey": {
            "description": "Document key.",
            "example": "CH-000001",
            "minLength": 1,
            "type": "string"
          },
          "id": {
            "description": "DIP identifier.",
            "example": "3f38d6f4-7b19-4db8-8d7d-693b84a9a2fb",
            "format": "uuid",
            "type": "string"
          },
          "object_key": {
            "description": "Object store key for the completed DIP.",
            "example": "dips/3f38d6f4-7b19-4db8-8d7d-693b84a9a2fb.zip",
            "minLength": 1,
            "type": "string"
          },
          "started_at": {
            "description": "RFC3339 timestamp.",
            "example": "2026-05-27T15:04:05Z",
            "format": "date-time",
            "type": "string"
          },
          "status": {
            "description": "Current DIP status.",
            "enum": [
              "queued",
              "in progress",
              "done",
              "failed"
            ],
            "example": "done",
            "type": "string"
          }
        },
        "required": [
          "id",
          "docKey",
          "status",
          "created_at"
        ],
        "type": "object"
      },
      "Error": {
        "description": "Invalid request parameters.",
        "example": {
          "fault": true,
          "id": "123abc",
          "message": "parameter 'p' must be an integer",
          "name": "bad_request",
          "temporary": false,
          "timeout": false
        },
        "properties": {
          "fault": {
            "description": "Is the error a server-side fault?",
            "example": false,
            "type": "boolean"
          },
          "id": {
            "description": "ID is a unique identifier for this particular occurrence of the problem.",
            "example": "123abc",
            "type": "string"
          },
          "message": {
            "description": "Message is a human-readable explanation specific to this occurrence of the problem.",
            "example": "parameter 'p' must be an integer",
            "type": "string"
          },
          "name": {
            "description": "Name is the name of this class of errors.",
            "example": "bad_request",
            "type": "string"
          },
          "temporary": {
            "description": "Is the error temporary?",
            "example": false,
            "type": "boolean"
          },
          "timeout": {
            "description": "Is the error a timeout?",
            "example": true,
            "type": "boolean"
          }
        },
        "required": [
          "name",
          "id",
          "message",
          "temporary",
          "timeout",
          "fault"
        ],
        "type": "object"
      }
    },
    "securitySchemes": {
      "bearer_header_Authorization": {
        "description": "Authenticate with an access token supplied as Authorization: Bearer [token]. Clients obtain tokens from an external OIDC provider.",
        "scheme": "bearer",
        "type": "http"
      }
    }
  },
  "info": {
    "description": "API used to request DIP creation and poll DIP details.",
    "title": "DIPs API",
    "version": "0.1.0"
  },
  "openapi": "3.0.3",
  "paths": {
    "/dips": {
      "post": {
        "description": "Request DIP creation for a document key.",
        "operationId": "DIPs#create",
        "requestBody": {
          "content": {
            "application/json": {
              "example": {
                "docKey": "CH-000001"
              },
              "schema": {
                "example": {
                  "docKey": "CH-000001"
                },
                "properties": {
                  "docKey": {
                    "description": "Document key used to create the DIP.",
                    "example": "CH-000001",
                    "minLength": 1,
                    "type": "string"
                  }
                },
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "content": {
              "application/json": {
                "example": {
                  "id": "3f38d6f4-7b19-4db8-8d7d-693b84a9a2fb"
                },
                "schema": {
                  "$ref": "#/components/schemas/CreateDIPResult"
                }
              }
            },
            "description": "Accepted response."
          },
          "400": {
            "content": {
              "application/vnd.goa.error": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            },
            "description": "not_valid: Invalid request parameters."
          },
          "401": {
            "content": {
              "application/vnd.goa.error": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            },
            "description": "unauthorized: Missing or invalid bearer token."
          },
          "500": {
            "content": {
              "application/vnd.goa.error": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            },
            "description": "internal_error: Unexpected server error."
          }
        },
        "security": [
          {
            "bearer_header_Authorization": []
          }
        ],
        "summary": "create DIPs",
        "tags": [
          "DIPs"
        ]
      }
    },
    "/dips/{id}": {
      "get": {
        "description": "Get DIP details.",
        "operationId": "DIPs#show",
        "parameters": [
          {
            "description": "DIP identifier.",
            "example": "3f38d6f4-7b19-4db8-8d7d-693b84a9a2fb",
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "description": "DIP identifier.",
              "example": "3f38d6f4-7b19-4db8-8d7d-693b84a9a2fb",
              "format": "uuid",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "example": {
                  "completed_at": "2026-05-27T15:04:05Z",
                  "created_at": "2026-05-27T15:04:05Z",
                  "docKey": "CH-000001",
                  "id": "3f38d6f4-7b19-4db8-8d7d-693b84a9a2fb",
                  "object_key": "dips/3f38d6f4-7b19-4db8-8d7d-693b84a9a2fb.zip",
                  "started_at": "2026-05-27T15:04:05Z",
                  "status": "done"
                },
                "schema": {
                  "$ref": "#/components/schemas/DIP"
                }
              }
            },
            "description": "OK response."
          },
          "401": {
            "content": {
              "application/vnd.goa.error": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            },
            "description": "unauthorized: Missing or invalid bearer token."
          },
          "404": {
            "content": {
              "application/vnd.goa.error": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            },
            "description": "not_found: DIP not found."
          },
          "500": {
            "content": {
              "application/vnd.goa.error": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            },
            "description": "internal_error: Unexpected server error."
          }
        },
        "security": [
          {
            "bearer_header_Authorization": []
          }
        ],
        "summary": "show DIPs",
        "tags": [
          "DIPs"
        ]
      }
    }
  },
  "servers": [
    {
      "description": "Default server for DIPs",
      "url": "http://localhost:80"
    }
  ],
  "tags": [
    {
      "description": "Requests DIP creation and reports their details.",
      "name": "DIPs"
    }
  ]
}
