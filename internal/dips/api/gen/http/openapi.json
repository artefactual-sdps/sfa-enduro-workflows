  "host": "localhost:80",
  "info": {
    "description": "API used to request DIP creation and poll DIP details.",
    "title": "DIPs API",
    "version": "0.1.0"
  },
  "paths": {
    "/dips": {
      "post": {
        "description": "Request DIP creation for a document key.",
        "operationId": "DIPs#create",
        "parameters": [
          {
            "in": "body",
            "name": "object",
            "required": true,
            "schema": {
              "properties": {
                "docKey": {
                  "description": "Document key used to create the DIP.",
                  "example": "CH-000001",
                  "minLength": 1,
                  "type": "string"
                }
              },
              "type": "object"
            }
          }
        ],
        "responses": {
          "202": {
            "description": "Accepted response.",
            "schema": {
              "$ref": "#/definitions/CreateDIPResult",
              "required": [
                "id"
              ]
            }
          },
          "400": {
            "description": "Bad Request response.",
            "schema": {
              "$ref": "#/definitions/DIPsCreateNotValidResponseBody"
            }
          },
          "401": {
            "description": "Unauthorized response.",
            "schema": {
              "$ref": "#/definitions/DIPsCreateUnauthorizedResponseBody"
            }
          },
          "500": {
            "description": "Internal Server Error response.",
            "schema": {
              "$ref": "#/definitions/DIPsCreateInternalErrorResponseBody"
            }
          }
        },
        "schemes": [
          "http"
        ],
        "security": [
          {
            "bearer_header_Authorization": null
          }
        ],
        "summary": "create DIPs",
        "tags": [
          "DIPs"
        ]
      }
    },
    "/dips/{id}": {
      "get": {
        "description": "Get DIP details.",
        "operationId": "DIPs#show",
        "parameters": [
          {
            "description": "DIP identifier.",
            "format": "uuid",
            "in": "path",
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "OK response.",
            "schema": {
              "$ref": "#/definitions/DIP",
              "required": [
                "id",
                "docKey",
                "status",
                "created_at"
              ]
            }
          },
          "401": {
            "description": "Unauthorized response.",
            "schema": {
              "$ref": "#/definitions/DIPsShowUnauthorizedResponseBody"
            }
          },
          "404": {
            "description": "Not Found response.",
            "schema": {
              "$ref": "#/definitions/DIPsShowNotFoundResponseBody"
            }
          },
          "500": {
            "description": "Internal Server Error response.",
            "schema": {
              "$ref": "#/definitions/DIPsShowInternalErrorResponseBody"
            }
          }
        },
        "schemes": [
          "http"
        ],
        "security": [
          {
            "bearer_header_Authorization": null
          }
        ],
        "summary": "show DIPs",
        "tags": [
          "DIPs"
        ]
      }
    }
  },
